# Supabase (https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Groq API (https://console.groq.com/keys) — nur für Server-seitiges Scoring
GROQ_API_KEY=your-groq-key-here

# WICHTIG: Nach dem ersten Setup müssen die Supabase-Keys rotiert werden,
# da sie versehentlich in der Git-Historie landen könnten.
